{
  "name": "sambar",
  "version": "0.0.0",
  "description": "A drop-in replacement for Electron, built on Bun and system WebKit.",
  "license": "MIT",
  "author": "Indrajeet O.",
  "homepage": "https://github.com/indrajeetor/sambar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indrajeetor/sambar.git"
  },
  "bugs": {
    "url": "https://github.com/indrajeetor/sambar/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./main": {
      "types": "./src/main/index.ts",
      "import": "./src/main/index.ts"
    },
    "./renderer": {
      "types": "./src/renderer/index.ts",
      "import": "./src/renderer/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "validate": "bun run format:check && bun run lint && bun run type-check && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "typescript": "6.0.3"
  }
}
