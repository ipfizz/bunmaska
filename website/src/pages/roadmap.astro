---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { VERSION } from "../site";
import RoadmapHero from "../components/roadmap/Hero.astro";
import RoadmapCurrentState from "../components/roadmap/CurrentState.astro";
import RoadmapPhases from "../components/roadmap/Phases.astro";
import RoadmapWindowsDetail from "../components/roadmap/WindowsDetail.astro";
import RoadmapCTA from "../components/roadmap/CTA.astro";
---

<Base title="Roadmap" description="What Bunmaska is building, where it is today, and the honest plan - including Windows (WinCairo WebKit, x64 today and ARM64 next, never WebView2).">
  <Nav />
  <main class="mx-auto max-w-6xl">
    <RoadmapHero version={VERSION} />
    <RoadmapCurrentState />
    <RoadmapPhases />
    <RoadmapWindowsDetail />
    <RoadmapCTA />
  </main>
  <Footer />
</Base>
