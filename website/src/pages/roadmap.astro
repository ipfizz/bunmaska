---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { VERSION } from "../site";
import RoadmapHero from "../components/roadmap/Hero.astro";
import RoadmapCurrentState from "../components/roadmap/CurrentState.astro";
import RoadmapTrack from "../components/roadmap/Track.astro";
import RoadmapWindowsDetail from "../components/roadmap/WindowsDetail.astro";
import RoadmapCTA from "../components/roadmap/CTA.astro";
---

<Base
  title="Roadmap"
  description="The road to beta: what's shipped at alpha, the exact milestones between here and v0.2.0-beta.1, and the checkable bar a beta has to clear - including the honest Windows (WinCairo, never WebView2) status."
>
  <Nav />
  <main class="mx-auto max-w-6xl">
    <RoadmapHero version={VERSION} />
    <RoadmapCurrentState />
    <RoadmapTrack />
    <RoadmapWindowsDetail />
    <RoadmapCTA />
  </main>
  <Footer />
</Base>
