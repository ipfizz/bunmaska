---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import SizeStory from "../components/SizeStory.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Moat from "../components/Moat.astro";
import Platforms from "../components/Platforms.astro";
import PinWebkits from "../components/PinWebkits.astro";
import Compare from "../components/Compare.astro";
import QuickStartWalkthrough from "../components/QuickStartWalkthrough.astro";
import CLICommands from "../components/CLICommands.astro";
import TradeOffs from "../components/TradeOffs.astro";
import FinalCTA from "../components/FinalCTA.astro";
import { faqPageJsonLd } from "../faq";
---

<Base jsonLd={faqPageJsonLd()}>
  <Nav />
  <Hero />
  <main class="max-w-6xl mx-auto">
    <FeatureGrid />
    <SizeStory />
    <Moat />
    <PinWebkits />
    <Platforms />
    <Compare />
    <QuickStartWalkthrough />
    <CLICommands />
    <TradeOffs />
    <FinalCTA />
  </main>
  <Footer />
</Base>
