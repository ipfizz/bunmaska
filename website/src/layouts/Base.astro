---
import "../fonts";
import "../styles/global.css";
import { VERSION, GITHUB, NPM } from "../site";

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  image?: string | undefined;
  imageAlt?: string | undefined;
  ogType?: "website" | "article" | undefined;
  noindex?: boolean | undefined;
  /** Extra JSON-LD graphs to append (FAQPage, BreadcrumbList, TechArticle, ...). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[] | undefined;
}

const DEFAULT_TITLE = "bunmaska - a drop-in Electron replacement built on Bun";
const DEFAULT_DESCRIPTION =
  "bunmaska is a drop-in Electron replacement built on Bun and your OS's own WebKit - no bundled Chromium, no node-gyp. Native modules that are just .ts files. Alpha, open source, MIT.";
const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = "/og.png",
  imageAlt = "bunmaska - a drop-in Electron replacement on Bun and system WebKit, no bundled Chromium",
  ogType = "website",
  noindex = false,
  jsonLd,
} = Astro.props;

// A page passes its keyword-rich phrase as `title`; the brand suffix is added
// once. The home page (no title) uses the full default.
const fullTitle = title ? `${title} | bunmaska` : DEFAULT_TITLE;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const isHome = Astro.url.pathname === "/";

// Site-wide identity graph. SoftwareApplication only where it belongs (home);
// WebSite everywhere. Page-specific graphs (FAQPage/Breadcrumb/TechArticle)
// are appended via the `jsonLd` prop.
const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "bunmaska",
  // The entity-split guard: the brand is one word, but engines tokenize it as
  // "bun maska" - claim the variants so the name renders and resolves as ours.
  alternateName: ["bun maska", "bunmaska.org"],
  url: Astro.site?.href,
  description: DEFAULT_DESCRIPTION,
};
const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "bunmaska",
  url: Astro.site?.href,
  logo: new URL("/logo.png", Astro.site).href,
  description:
    "bunmaska is a desktop app framework - a drop-in Electron replacement built on Bun and the system WebKit.",
  foundingDate: "2026",
  sameAs: [GITHUB, NPM],
};
const softwareApp = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "bunmaska",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  description: DEFAULT_DESCRIPTION,
  url: Astro.site?.href,
  softwareVersion: VERSION,
  license: "https://opensource.org/licenses/MIT",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  sameAs: [GITHUB, NPM],
};
const extra = jsonLd === undefined ? [] : Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const graphs = [website, ...(isHome ? [organization, softwareApp] : []), ...extra];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fcfcfb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0c0b" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:site_name" content="bunmaska" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {graphs.map((g) => <script is:inline type="application/ld+json" set:html={JSON.stringify(g)} />)}
    {/* No-flash theme bootstrap - runs before paint */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t === "dark" || t === "light") {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
    <script>
      // Scroll reveals: hide-then-show only when we can actually observe.
      const els = document.querySelectorAll(".reveal");
      const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (els.length && motionOk && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("reveal-in");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.05 },
        );
        for (const el of els) {
          // Never hide what's already on screen at load.
          if (el.getBoundingClientRect().top > window.innerHeight) {
            el.classList.add("reveal-init");
            io.observe(el);
          }
        }
      }
    </script>
  </body>
</html>
