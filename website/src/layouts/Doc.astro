---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Sidebar from "../components/Sidebar.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Toc from "../components/Toc.astro";
import PrevNext from "../components/PrevNext.astro";
import { prevNext, breadcrumbItems } from "../nav";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  title: string;
  description?: string | undefined;
  seoTitle?: string | undefined;
  slug: string;
  headings: Heading[];
}

const { title, description, seoTitle, slug, headings } = Astro.props;
const { prev, next } = prevNext(slug);
const abs = (path: string) => new URL(path, Astro.site).href;

// Breadcrumb graph (Home > Group > Page) built from the nav, absolute URLs.
const crumbs = [{ label: "Home", href: "/" }, ...breadcrumbItems(slug)];
const breadcrumbList = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: crumbs.map((c, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: c.label,
    item: abs(c.href),
  })),
};
// Every doc is a TechArticle; dates omitted rather than faked.
const techArticle = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: title,
  ...(description ? { description } : {}),
  url: abs(`/docs/${slug}`),
  author: { "@type": "Organization", name: "bunmaska" },
  publisher: { "@type": "Organization", name: "bunmaska" },
};
---

<Base
  title={seoTitle ?? title}
  description={description}
  ogType="article"
  jsonLd={[breadcrumbList, techArticle]}
>
  <Nav />
  <div class="mx-auto w-full max-w-[88rem] px-5 md:px-8">
    <div
      class="grid grid-cols-1 py-8 lg:grid-cols-[15rem_minmax(0,1fr)_13rem] lg:gap-x-10 lg:py-12 xl:gap-x-16"
    >
      {/* Mobile: collapsible docs nav (the sidebar is hidden below lg). */}
      <details class="docs-menu mb-6 lg:hidden">
        <summary
          class="flex cursor-pointer items-center justify-between rounded-sm border border-border bg-surface px-3.5 py-2.5 text-sm text-text-muted"
        >
          <span>Documentation menu</span>
          <span class="chevron text-text-faint" aria-hidden="true">›</span>
        </summary>
        <div class="mt-3 rounded-sm border border-border bg-surface p-4">
          <Sidebar current={slug} />
        </div>
      </details>

      <aside
        class="hidden lg:block lg:sticky lg:top-20 lg:max-h-[calc(100dvh-6rem)] lg:self-start lg:overflow-y-auto lg:overscroll-contain lg:pb-10 lg:pr-1"
      >
        <Sidebar current={slug} />
      </aside>

      <div class="min-w-0">
        <Breadcrumbs slug={slug} />
        <header class="mt-4 border-b border-border pb-6">
          <h1 class="text-[1.75rem] leading-[1.15] font-medium tracking-tight text-balance">
            {title}
          </h1>
          {description && <p class="lead mt-3">{description}</p>}
        </header>
        <article class="prose mt-7">
          <slot />
        </article>
        <PrevNext prev={prev} next={next} />
      </div>

      <aside
        class="hidden lg:block lg:sticky lg:top-20 lg:max-h-[calc(100dvh-6rem)] lg:self-start lg:overflow-y-auto lg:overscroll-contain lg:pb-10"
      >
        <Toc headings={headings} />
      </aside>
    </div>
  </div>
  <Footer />
</Base>

<style>
  .lead {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 66ch;
  }
  .docs-menu summary {
    list-style: none;
  }
  .docs-menu summary::-webkit-details-marker {
    display: none;
  }
  .docs-menu .chevron {
    transition: transform 0.15s ease;
  }
  .docs-menu[open] .chevron {
    transform: rotate(90deg);
  }
</style>

<script>
  // The copy buttons themselves are injected at build time (rehype-copy-button),
  // so the icon ships in the SSR'd HTML. This only wires the click behaviour.
  document
    .querySelectorAll<HTMLButtonElement>(".copy-btn--prose")
    .forEach((btn) => {
      btn.addEventListener("click", async () => {
        const pre = btn.closest("pre");
        const code = pre?.querySelector("code");
        const text = (code ?? pre)?.textContent ?? "";
        try {
          await navigator.clipboard.writeText(text);
          btn.classList.add("copied");
          setTimeout(() => btn.classList.remove("copied"), 1400);
        } catch {
          // Clipboard access denied - the copy button is a progressive enhancement.
        }
      });
    });
</script>
