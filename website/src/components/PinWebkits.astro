---
import CodeBlock from "./CodeBlock.astro";

const HEAD = "text-[1.5rem] leading-[1.2] font-semibold tracking-tight";

const pinExample = `import { defineConfig } from "bunmaska/config";

export default defineConfig({
  // Pin the exact WebKit you tested. Shared across apps. No global switch.
  engine: { webkit: "webkitgtk-6.0-2.52.4-bunmaska1-linux-x64" },
});`;
---

<section class="border border-border">
  <div class="wrap py-12 sm:py-14">
    <div class="mx-auto max-w-[48ch] text-center">
      <h2 class={HEAD}>
        Pin the WebKit you
        <span
          class="text-[1.05em] italic font-normal text-accent-text"
          style="font-family:var(--font-serif);">actually tested.</span
        >
      </h2>
      <p class="mt-4 text-sm text-text-faint">
        By default, apps render on the system's WebKit — that's what keeps them
        small. When byte-for-byte consistency matters, pin a specific build
        instead.
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-2xl">
      <CodeBlock code={pinExample} lang="ts" title="bunmaska.config.ts" />
    </div>

    <dl
      class="mx-auto mt-10 max-w-2xl grid grid-cols-1 gap-px border border-border sm:grid-cols-3"
    >
      <div class="flex flex-col gap-1 bg-surface px-6 py-5">
        <dt class="text-xs font-semibold text-accent-text">Engine resolution</dt>
        <dd class="text-sm text-text-muted">
          Resolved from a shared store — downloaded once, used by every app that
          pins it.
        </dd>
      </div>
      <div class="flex flex-col gap-1 bg-surface px-6 py-5">
        <dt class="text-xs font-semibold text-accent-text">Per-app versioning</dt>
        <dd class="text-sm text-text-muted">
          Different apps can pin different versions side by side. No global
          switch.
        </dd>
      </div>
      <div class="flex flex-col gap-1 bg-surface px-6 py-5">
        <dt class="text-xs font-semibold text-accent-text">Availability</dt>
        <dd class="text-sm text-text-muted">
          Linux-first today. macOS and Windows (WinCairo, not Chromium) on the
          way.
        </dd>
      </div>
    </dl>
  </div>
</section>
