---
import BundleSizeCounter from "./ui/BundleSizeCounter";
---

<section class="section-border reveal">
  <div class="bento">
    <div class="cell col-span-6 md:col-span-3">
      <p class="eyebrow">The download</p>
      <BundleSizeCounter client:visible />
      <p class="body mt-auto">
        A minimal Electron app starts at 150&thinsp;MB+. This is the whole
        thing — no Chromium, no giant runtime, only what your app needs.
      </p>
    </div>
    <div class="cell col-span-6 md:col-span-3">
      <p class="eyebrow">Familiar developer experience</p>
      <h3 class="heading-lg">
        Electron-style APIs.<br />
        Native implementation.
      </h3>
      <p class="body mt-auto">
        Keep the mental model — <code>app</code>, <code>BrowserWindow</code>,
        <code>ipcMain</code> — and drop the bundled browser. Bun runs your main
        process; the OS renders your windows.
      </p>
    </div>
    <div class="cell col-span-6 md:col-span-2">
      <p class="stat">0</p>
      <h3 class="heading">compiled native code</h3>
      <p class="body">
        Pure <code>bun:ffi</code>. No node-gyp, no rebuild scripts, no compiler
        adventures.
      </p>
    </div>
    <div class="cell col-span-6 md:col-span-2">
      <p class="stat">0</p>
      <h3 class="heading">runtime dependencies</h3>
      <p class="body">Fewer moving parts. A smaller attack surface.</p>
    </div>
    <div class="cell col-span-6 md:col-span-2">
      <p class="stat">3</p>
      <h3 class="heading">platforms</h3>
      <p class="body">macOS · Linux · Windows (beta) — the system's own WebKit on every one.</p>
    </div>
  </div>
</section>

<style>
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    background-color: var(--surface);
  }

  .cell {
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-height: 180px;
  }

  /* The stat role rides the serif display voice — numbers as typography,
     not icon tiles. */
  .stat,
  .cell :global(.stat) {
    font-family: var(--font-serif);
    font-size: 2.75rem;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--accent-text);
    margin-bottom: auto;
  }

  .heading-lg {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.25;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .heading {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
  }

  .body {
    font-size: var(--text-sm);
    color: var(--text-faint);
    line-height: 1.6;
  }

  .body code {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
</style>
