---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="badge">
  <div class="badge-border"></div>
  <div class="badge-content">
    <span>{text}</span>
  </div>
</div>

<style>
  .badge {
    position: relative;
    display: inline-block;
    padding: 1px;
    border-radius: 9999px;
    overflow: hidden;
  }

  .badge-border {
    position: absolute;
    width: 180%;
    height: 400%;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: linear-gradient(
      90deg,
      transparent 35%,
      transparent 42%,
      rgba(255, 210, 90, 0.2) 46%,
      rgba(255, 240, 180, 0.95) 50%,
      rgba(255, 210, 90, 0.25) 54%,
      transparent 58%,
      transparent 100%
    );

    animation: spin 10s linear infinite;
  }

  .badge-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 1rem;
    border-radius: inherit;
    background: rgba(18, 18, 18, 0.95);
    backdrop-filter: blur(12px);
    color: var(--accent-text);
    font-size: 0.75rem;
    font-weight: 600;
  }

  @keyframes spin {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }

    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }
</style>
