---
import { Code } from "astro:components";
import type { BundledLanguage } from "shiki";

interface Props {
  code: string;
  lang?: BundledLanguage;
  title?: string;
}

const { code, lang = "ts", title } = Astro.props;
---

<div class="codepanel my-5">
  <div class="codepanel-bar">
    <span class="flex items-center gap-2.5">
      <span class="codepanel-dots" aria-hidden="true"><i></i><i></i><i></i></span>
      <span>{title ?? lang}</span>
    </span>
    <button type="button" class="copy-btn" data-code={code} aria-label="Copy code"></button>
  </div>
  <Code code={code} lang={lang} themes={{ light: "github-light", dark: "github-dark" }} />
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>(".codepanel .copy-btn[data-code]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset["code"] ?? "");
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 1400);
      } catch {}
    });
  });
</script>
