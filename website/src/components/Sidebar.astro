---
import { sidebar } from "../nav";

interface Props {
  current: string;
}
const { current } = Astro.props;
---

<nav aria-label="Docs">
  {
    sidebar.map((group) => (
      <div class="mb-6">
        <p class="mb-2 text-[0.6875rem] font-medium uppercase tracking-[0.08em] text-text-faint">
          {group.title}
        </p>
        <ul class="border-l border-border">
          {group.items.map((item) => {
            const active = item.slug === current;
            return (
              <li>
                <a
                  href={`/docs/${item.slug}`}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "-ml-px block border-l py-[0.3rem] pl-3 pr-2 text-[0.8125rem] leading-snug transition-colors",
                    active
                      ? "border-accent font-medium text-accent-text"
                      : "border-transparent text-text-muted hover:border-border-strong hover:text-text",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</nav>
