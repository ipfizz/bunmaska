---
import { sidebar } from "../nav";

interface Props {
  current: string;
}
const { current } = Astro.props;
---

<nav aria-label="Docs" class="text-sm">
  {
    sidebar.map((group) => (
      <div class="mb-7">
        <p class="eyebrow mb-2.5">{group.title}</p>
        <ul class="space-y-0.5">
          {group.items.map((item) => {
            const active = item.slug === current;
            return (
              <li class="ml-1">
                <a
                  href={`/docs/${item.slug}`}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "block border-l-3 p-1.5 pl-3 transition-colors",
                    active
                      ? "bg-accent-bg border-accent-text font-medium text-text"
                      : "border-transparent text-text-muted hover:bg-accent-bg hover:text-text",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</nav>
