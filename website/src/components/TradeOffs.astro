---
import { HEAD } from "../styles/constants";
import { homeFaq } from "../faq";

// Shared with the home FAQPage JSON-LD (index.astro) so the markup matches the
// visible cards exactly — a mismatch drops the rich result.
const faqs = homeFaq.map((item) => [item.q, item.a] as const);
---

<section class="relative overflow-hidden py-12 section-border">
  <div
    class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_center,rgba(255,191,73,0.05),transparent_60%)]"
  >
  </div>

  <div class="relative wrap">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow mb-4">Trade-offs</p>
      <h2 class={HEAD}>
        It's alpha.
        <span
          class="serif-accent text-accent-text"
        >
          We're not going to pretend
        </span>
        otherwise.
      </h2>
      <p class="mt-6 text-sm leading-relaxed text-text-muted">
        Things will move. Some things will break. We'll tell you which ones. If
        it's still 2027 and this still says
        <span class="text-text font-medium">alpha</span>, open an issue titled
        <span class="text-text font-medium"> "are you OK." </span>
      </p>
    </div>
    <div class="mx-auto mt-16 grid max-w-5xl gap-5 md:grid-cols-2">
      {
        faqs.map(([q, a]) => (
          <div
            class="rounded-md border border-border bg-bg-subtle/50 p-6 transition-colors duration-200 hover:border-accent-text/30"
          >
            <h3 class="font-medium">{q}</h3>

            <p class="mt-3 leading-relaxed text-text-muted">{a}</p>
          </div>
        ))
      }
    </div>
    <div class="mt-14 text-center">
      <p
        class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm text-text-faint"
      >
        <span>⚡</span>
        Ship fast. Break carefully. Fix publicly.
      </p>
    </div>
  </div>
</section>
