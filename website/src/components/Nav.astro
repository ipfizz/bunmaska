---
import ThemeToggle from "./ui/ThemeToggle.tsx";
import { VERSION, GITHUB } from "../site";
import { Icon } from "astro-icon/components";

const LINKS = [
  { href: "/docs/introduction", label: "Docs" },
  { href: "/roadmap", label: "Roadmap" },
  { href: "/docs/native-modules/overview", label: "Native Modules" },
];
---

<header
  id="site-nav"
  class="sticky top-0 z-50 border-b border-transparent backdrop-blur transition-colors"
>
  <div class="wrap flex h-16 items-center justify-between">
    <div class="flex items-baseline gap-2">
      <a
        href="/"
        class="text-base font-semibold tracking-tight uppercase"
        aria-label="Bunmaska home">Bunmaska</a
      >
      <a
        href="/docs/changelog"
        class="tag font-mono transition-colors hover:text-text"
        style="height:1.35rem;"
        title="Changelog"
      >
        v{VERSION}
      </a>
    </div>

    <nav class="flex items-center gap-2" aria-label="Primary">
      <div class="hidden items-center gap-2 md:flex">
        {
          LINKS.map((l) => (
            <a
              href={l.href}
              class="rounded-sm px-3 py-2 text-sm text-text-muted transition-colors hover:text-text"
            >
              {l.label}
            </a>
          ))
        }
      </div>
      <span
        class="ml-1 border border-[var(--border)] rounded-[var(--radius-sm)] p-2"
      >
        <a
          href={GITHUB}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Bunmaska on GitHub"
        >
          <Icon
            name="mdi:github"
            class="w-3.5 h-3.5 sm:w-4 sm:h-4 md:w-5 md:h-5"
          />
        </a>
      </span>
      <span class="ml-1">
        <ThemeToggle client:load />
      </span>
      <button
        id="nav-toggle"
        type="button"
        class="ml-1 inline-flex items-center justify-center border border-[var(--border)] rounded-[var(--radius-sm)] p-2 text-text-muted transition-colors hover:text-text md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </nav>
  </div>

  <div id="mobile-menu" hidden class="border-t border-border md:hidden">
    <nav class="wrap flex flex-col gap-1 py-3" aria-label="Mobile">
      {
        LINKS.map((l) => (
          <a
            href={l.href}
            class="rounded-sm px-3 py-2.5 text-sm text-text-muted transition-colors hover:bg-bg-subtle hover:text-text"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  #site-nav {
    background: color-mix(in srgb, var(--bg) 78%, transparent);
  }
  #site-nav.scrolled {
    border-bottom-color: var(--border);
  }
</style>

<script>
  const nav = document.getElementById("site-nav");
  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle("scrolled", window.scrollY > 8);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      menu.hidden = !open;
    };
    toggle.addEventListener("click", () =>
      setOpen(toggle.getAttribute("aria-expanded") !== "true"),
    );
    menu.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => setOpen(false)),
    );
    // Snap back to the desktop layout if the viewport grows past the md breakpoint.
    window
      .matchMedia("(min-width: 768px)")
      .addEventListener("change", (e) => {
        if (e.matches) setOpen(false);
      });
  }
</script>
