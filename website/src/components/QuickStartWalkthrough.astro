---
import { HEAD } from "../styles/constants";
import CodeBlock from "./ui/CodeBlock.astro";

const helloApp = `import { app, BrowserWindow } from "bunmaska";

app.whenReady().then(() => {
  const win = new BrowserWindow({ width: 960, height: 720 });
  win.loadURL("https://example.com");
});`;
---

<section class="relative section-border py-12 overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top,rgba(255,191,73,0.08),transparent_55%)]"
  >
  </div>
  <div class="relative wrap">
    <div class="text-center space-y-6">
      <p class="eyebrow">Developer Experience</p>

      <h2 class={HEAD}>
        From zero to a window in about
        <span
          class="italic font-normal text-accent-text"
          style="font-family:var(--font-serif)"
        >
          ninety seconds.
        </span>
      </h2>
      <div
        class="flex flex-wrap items-center justify-center gap-3 text-sm text-text-muted"
      >
        <span class="rounded-full border border-border px-3 py-1 font-mono">
          bunmaska init
        </span>
        <span>→</span>
        <span class="rounded-full border border-border px-3 py-1 font-mono">
          bunmaska dev
        </span>
        <span>→</span>
        <span class="rounded-full border border-border px-3 py-1 font-mono">
          bunmaska build
        </span>
      </div>
      <p class="text-center mt-4 text-sm text-text-faint">
        Create, run and package a native desktop application using the same
        tools you already use every day.
      </p>
    </div>
    <div class="mx-auto mt-8 max-w-2xl">
      <CodeBlock code={helloApp} lang="ts" title="src/main.ts" />
      <div
        class="mt-6 flex items-center justify-center gap-2 text-sm text-text-faint"
      >
        <span>✓ Standalone executable</span>
        <span>•</span>
        <span>✓ No runtime install</span>
        <span>•</span>
        <span>✓ Double-click to launch</span>
      </div>
    </div>
  </div>
</section>
