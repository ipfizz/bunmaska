---
const rows = [
  {
    feature: "Download size",
    electron: "150 MB+",
    bunmaska: "~16–23 MB",
  },
  {
    feature: "Installed size",
    electron: "~220 MB",
    bunmaska: "~60 MB",
  },
  {
    feature: "Rendering engine",
    electron: "Bundled Chromium (every app, again)",
    bunmaska: "OS-native WebKit (not bundled)",
  },
  {
    feature: "Native modules",
    electron: "node-gyp / N-API / electron-rebuild",
    bunmaska: "a .ts file that dlopens the OS",
  },
  {
    feature: "Compile step",
    electron: "Yes, and it'll fail somewhere",
    bunmaska: "None",
  },
  {
    feature: "Runtime deps",
    electron: "Several",
    bunmaska: "Zero",
  },
  {
    feature: "Runtime",
    electron: "Node + V8",
    bunmaska: "Bun + JavaScriptCore",
  },
  {
    feature: "Platforms",
    electron: "Win / macOS / Linux",
    bunmaska: "Win (x64) / macOS / Linux",
  },
  {
    feature: "Familiar API",
    electron: "The original",
    bunmaska: "Drop-in, ~70–80% parity",
  },
];
---

<section class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Heading -->

    <div class="text-center space-y-4">
      <p
        class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-text"
      >
        Bunmaska vs Electron
      </p>

      <h2 class="text-4xl font-bold md:text-5xl">
        Same shape.
        <span
          class="font-normal italic text-accent-text"
          style="font-family: var(--font-serif);"
        >
          A tenth of the weight.
        </span>
      </h2>
    </div>

    <!-- Table -->

    <div
      class="mt-14 overflow-hidden rounded-3xl border border-[var(--border)] bg-[rgba(255,255,255,0.01)] backdrop-blur"
    >
      <div class="grid grid-cols-3 border-b border-[var(--border)]">
        <div class="p-6"></div>

        <div class="p-6 font-semibold">Electron</div>

        <div class="p-6 font-semibold text-accent-text">Bunmaska</div>
      </div>

      {
        rows.map((row) => (
          <div class="grid grid-cols-3 border-b border-[var(--border)] last:border-b-0">
            <div class="p-6 text-[var(--text-muted)]">{row.feature}</div>

            <div class="p-6">{row.electron}</div>

            <div class="p-6 font-semibold text-white">{row.bunmaska}</div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm text-[var(--text-muted)]">
      We left a few rows where Electron still wins. We're allergic to lying in
      tables too.
    </p>
  </div>
</section>
