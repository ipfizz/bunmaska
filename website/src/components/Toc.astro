---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <nav aria-label="On this page" class="toc">
      <p class="mb-2 text-[0.6875rem] font-medium uppercase tracking-[0.08em] text-text-faint">
        On this page
      </p>
      <ul class="space-y-0.5">
        {items.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              data-toc={h.slug}
              class:list={[
                "block py-[0.2rem] text-[0.8125rem] leading-snug text-text-faint transition-colors hover:text-text",
                h.depth === 3 && "pl-3",
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc a[data-active="true"] {
    color: var(--accent-text);
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>(".toc a[data-toc]"));
  if (links.length) {
    const map = new Map(links.map((l) => [l.dataset["toc"], l]));
    // threshold 0 + a top band: long wrapped headings still activate (threshold 1 never fires for them).
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            for (const l of links) l.removeAttribute("data-active");
            const link = map.get(e.target.id);
            if (link) link.setAttribute("data-active", "true");
          }
        }
      },
      { rootMargin: "-72px 0px -70% 0px", threshold: 0 },
    );
    document.querySelectorAll("article h2[id], article h3[id]").forEach((h) => observer.observe(h));
  }
</script>
