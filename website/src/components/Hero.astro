---
import DashedBox from "../components/DashedBox.astro";
import codeblock from "../assets/code_block.png";
import { Image } from "astro:assets";
import InstallTabs from "./InstallTabs";

const HEAD = "text-[1.5rem] leading-[1.2] font-semibold tracking-tight";
---

<section class="relative overflow-hidden">
  <DashedBox columns={16} class="h-full w-full py-12">
    <div
      class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top,rgba(255,191,73,0.08),transparent_55%)]"
    >
    </div>
    <div class="flex flex-col h-full items-center justify-center space-y-4">
      <div
        class="border px-4 py-1 rounded-full bg-yellow-700/10 backdrop-blur-lg"
      >
        <p class="text-accent-text text-xs font-semibold">
          Speed of Bun + Flexibility of WebKit
        </p>
      </div>
      <div class="text-center">
        <p style="font-family:var(--font-serif);" class="text-4xl font-bold">
          Build an app before you finish your <span class="text-accent-text"
            >bun-maska & chai.</span
          >
        </p>
      </div>
      <div class="relative">
        <Image src={codeblock} alt="Hero" class="w-150 h-auto" />
      </div>
      <h2 class={HEAD}>
        From zero to a window in about <span
          class="text-[1.1em] italic font-normal text-accent-text"
          style="font-family:var(--font-serif);"
        >
          ~ 90 seconds.</span
        >
      </h2>
      <div class="flex justify-center relative w-full">
        <InstallTabs client:visible />
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/docs/quickstart" class="btn btn-accent">Get started →</a>
        <a href="/docs/introduction" class="btn btn-ghost">View Docs</a>
      </div>
    </div>
  </DashedBox>
</section>
