---
import { DISPLAY } from "../styles/constants.ts";
import DashedBox from "./DashedBox.astro";
import CodeBlock from "./ui/CodeBlock.astro";
import InstallTabs from "./ui/InstallTabs.tsx";

const helloApp = `import { app, BrowserWindow } from "bunmaska";

app.whenReady().then(() => {
  const win = new BrowserWindow({
    width: 960,
    height: 720,
    title: "Hello Bunmaska",
  });
  win.loadURL("https://example.com");
});`;
---

<section class="relative overflow-hidden">
  <DashedBox columns={16} class="h-full w-full py-14 sm:py-16">
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(55% 45% at 50% 0%, color-mix(in srgb, var(--accent) 9%, transparent), transparent 70%);"
    >
    </div>
    <div class="relative mx-auto flex max-w-3xl flex-col items-center gap-7 px-6 text-center">
      <p class="tag font-mono">Bun + system WebKit · no Chromium</p>
      <h1 class={`${DISPLAY} max-w-[24ch]`}>
        Build an app before you finish your
        <span class="italic text-accent-text">bun-maska &amp; chai.</span>
      </h1>
      <p class="max-w-[52ch] text-text-muted">
        A drop-in Electron replacement on Bun and the WebKit your OS already
        ships. From zero to a native window in about
        <span class="serif-note text-accent-text">ninety seconds.</span>
      </p>
      <div class="w-full max-w-xl text-left">
        <CodeBlock code={helloApp} lang="ts" title="src/main.ts" />
      </div>
      <div class="flex w-full justify-center">
        <InstallTabs client:visible />
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/docs/quickstart" class="btn btn-accent">Get started →</a>
        <a href="/docs/introduction" class="btn btn-ghost">View Docs</a>
      </div>
    </div>
  </DashedBox>
</section>
