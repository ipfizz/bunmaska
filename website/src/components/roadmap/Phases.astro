---
import { HEAD } from "../../styles/constants";

type Status = "shipping" | "in-progress" | "planned" | "future";

const STATUS: Record<Status, { dot: string; text: string; label: string }> = {
  shipping: { dot: "var(--success)", text: "text-success", label: "Shipping now" },
  "in-progress": { dot: "var(--accent)", text: "text-accent-text", label: "In progress" },
  planned: { dot: "var(--border-strong)", text: "text-text-muted", label: "Planned" },
  future: { dot: "var(--border-strong)", text: "text-text-faint", label: "Future · v3+" },
};

const phases: { status: Status; title: string; note?: string; items: string[] }[] = [
  {
    status: "shipping",
    title: "The framework + the engine store",
    note: "macOS, Linux, and Windows. Alpha, and we'll admit it.",
    items: [
      "An Electron-shaped API on Bun + WebKit - ~70-80% parity, on macOS, Linux, and Windows.",
      "Buildless native modules: a .ts file that dlopens the OS. No node-gyp. No rebuild. Ever.",
      "The CLI - init / dev / build - producing real .app and .deb distributables, plus a pure-Bun auto-updater.",
      'The pinned-WebKit engine store: side-by-side, content-addressed, signature-verified installs - the "tested == shipped" tier.',
      "A self-contained, relocatable WebKit you can pin and ship - its full dependency closure travels with it, loaded from the shared store.",
    ],
  },
  {
    status: "in-progress",
    title: "The road to public",
    note: "everything between here and `npm i bunmaska`.",
    items: [
      "Host the prebuilt engines on a signed CDN (Cloudflare R2 - zero egress fees on big binaries).",
      "The render pass for the relocatable engine: it loads today; next it draws.",
      "Publish the first bunmaska to npm; bunmaska.org goes live.",
      "Starter boilerplates - React + Tailwind + Bunmaska, ready to clone.",
    ],
  },
  {
    status: "planned",
    title: "Depth + macOS pinning",
    items: [
      "Fill the API gaps: session.cookies, BrowserWindow setters, richer webContents events.",
      "Cross-distro engine builds (an old-glibc base, so one build runs across distros).",
      "A pinned macOS engine - opt-in, after a notarization spike. System WKWebView stays the default.",
      "Engine delivery to end users: embed-in-bundle, or fetch-on-first-run. Never something the user types.",
    ],
  },
  {
    status: "shipping",
    title: "Windows",
    note: "x64 ships - on our terms, never Chromium.",
    items: [
      "A from-scratch Win32 backend on pure bun:ffi - native windows, a cooperative pump, IPC with context isolation, an application menu bar, and the full secondary-module set (clipboard incl. images, dialogs, tray, notifications, safeStorage via DPAPI, screen, shell, global shortcuts, power, native theme, session). Green on a windows-latest CI runner alongside macOS and Linux.",
      "WinCairo WebKit, compiled from WebKit source by us (a clang-cl build, proven end-to-end), bundled or loaded from the engine store. Never WebView2 - that's Chromium.",
      "x64 today; ARM64 is on the roadmap (upstream WinCairo is x64-only). Never 32-bit.",
      "A few APIs are engine-blocked on WinCairo - custom protocol://, printToPDF, capturePage - and we document each rather than fake it.",
    ],
  },
];
---

<section class="section-border py-16 sm:py-20">
  <div class="wrap">
    <div class="mx-auto max-w-4xl">
      <div class="mb-8 text-center">
        <p class="eyebrow mb-4">The phases</p>
        <h2 class={HEAD}>What ships now, what comes next, and what is still deliberately slow.</h2>
      </div>
      <div class="grid gap-5">
        {
          phases.map((phase) => (
            <div class="group rounded-sm border border-border bg-surface p-7 transition-colors duration-200 hover:border-border-strong hover:bg-bg-subtle/60">
              <div class="flex flex-wrap items-center gap-3">
                <span
                  class={`inline-flex items-center gap-1.5 rounded-xs border border-border bg-bg px-3 py-1 text-xs font-semibold uppercase tracking-wide ${STATUS[phase.status].text}`}
                >
                  <span class="h-1.5 w-1.5 rounded-full" style={`background:${STATUS[phase.status].dot};`} aria-hidden="true" />
                  {STATUS[phase.status].label}
                </span>
                {phase.note && <p class="serif-note text-text-faint">{phase.note}</p>}
              </div>
              <h3 class="mt-4 text-lg font-semibold tracking-tight">{phase.title}</h3>
              <ul class="mt-4 space-y-3">
                {phase.items.map((item) => (
                  <li class="flex gap-3 text-text-muted">
                    <span
                      class="mt-[0.55em] h-1.5 w-1.5 flex-none rounded-full"
                      style={`background:${STATUS[phase.status].dot};`}
                      aria-hidden="true"
                    />
                    <span set:html={item.replace(/`([^`]+)`/g, '<code class="font-mono text-[0.85em] text-text">$1</code>')} />
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>