---
import { HEAD } from "../../styles/constants";
import { milestones, STATUS_LABEL } from "../../roadmap-data";

// One quiet color per status - used for the status label and the "now"/"beta"
// row emphasis. No per-bullet color, no pills; hierarchy comes from tint + type.
const STATUS_CLASS: Record<string, string> = {
  shipped: "text-success",
  now: "text-accent-text",
  next: "text-text-muted",
  planned: "text-text-muted",
  beta: "text-accent-text",
  later: "text-text-faint",
};

const inlineCode = (text: string): string =>
  text.replace(/`([^`]+)`/g, '<code class="font-mono text-[0.85em] text-text">$1</code>');
---

<section class="section-border py-16 sm:py-20">
  <div class="wrap">
    <div class="mx-auto mb-12 max-w-[46ch] text-center">
      <p class="eyebrow mb-4">Release plan</p>
      <h2 class={HEAD}>
        From here to a beta you can <span class="serif-accent text-accent-text">check.</span>
      </h2>
    </div>

    <ol class="mx-auto max-w-4xl overflow-hidden rounded-md border border-border bg-surface">
      {
        milestones.map((m, i) => (
          <li
            class:list={[
              "release",
              m.status,
              i > 0 && "border-t border-border",
              m.status === "now" && "is-now",
              m.status === "beta" && "is-beta",
            ]}
          >
            <div class="grid gap-x-8 gap-y-3 p-6 sm:p-7 md:grid-cols-[10rem_minmax(0,1fr)]">
              <div class="meta">
                <div class="version">{m.version}</div>
                <div class:list={["status", STATUS_CLASS[m.status]]}>{STATUS_LABEL[m.status]}</div>
              </div>

              <div class="min-w-0">
                <h3 class="title">{m.title}</h3>
                <p class="note">{m.note}</p>
                <ul class="mt-4 space-y-2">
                  {m.items.map((item) => (
                    <li class="item">
                      <span class="marker" aria-hidden="true" />
                      <span set:html={inlineCode(item)} />
                    </li>
                  ))}
                </ul>
                {m.exit && (
                  <p class="exit">
                    <span class="exit-label">Exit test</span>
                    {m.exit}
                  </p>
                )}
              </div>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .release.is-now {
    background: color-mix(in srgb, var(--accent-bg) 55%, transparent);
  }
  .release.is-beta {
    background: color-mix(in srgb, var(--accent-bg) 55%, transparent);
    box-shadow: inset 3px 0 0 var(--accent);
  }

  .version {
    font-size: 1rem;
    font-weight: 550;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .status {
    margin-top: 0.2rem;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  /* On mobile the meta column stacks above content; sit version + status inline. */
  @media (max-width: 767px) {
    .meta {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
    }
    .status {
      margin-top: 0;
    }
  }

  .title {
    font-size: 1.0625rem;
    font-weight: 550;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .note {
    margin-top: 0.25rem;
    font-size: var(--text-sm);
    color: var(--text-faint);
  }

  .item {
    display: flex;
    gap: 0.7rem;
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--text-muted);
  }
  .marker {
    margin-top: 0.62em;
    flex: none;
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--border-strong);
  }

  .exit {
    margin-top: 1.1rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--border);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--text-faint);
  }
  .exit-label {
    margin-right: 0.6rem;
    font-weight: 550;
    color: var(--accent-text);
  }
</style>
