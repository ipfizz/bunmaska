---
import { DISPLAY } from "../../styles/constants";

interface Props {
  version: string;
}

const { version } = Astro.props;
---

<section class="relative overflow-hidden section-border">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(55% 45% at 50% 0%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 70%);"
  >
  </div>
  <div class="wrap pb-14 pt-14 text-center sm:pb-16">
    <p class="eyebrow mb-5">Roadmap</p>
    <h1 class={`mx-auto max-w-[18ch] ${DISPLAY}`} style="letter-spacing:-0.01em;">
      The road to <span class="italic text-accent-text">beta.</span>
    </h1>
    <p class="mx-auto mt-6 max-w-[58ch] text-text-muted">
      An Electron-class developer experience that ships tiny apps on WebKit
      instead of a bundled browser — with native modules that never need a
      compiler. Below: what's shipped, the exact stops between here and beta,
      and what "beta" has to prove before we'll say the word. No vapor; if it
      isn't built, it says so.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
      <span class="tag font-mono">v{version}</span>
      <span class="tag">macOS · Linux · Windows (beta)</span>
      <span class="tag">MIT</span>
    </div>
  </div>
</section>
