---
import { DISPLAY } from "../styles/constants";
---

<section class="relative overflow-hidden">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(55% 60% at 50% 100%, color-mix(in srgb, var(--accent) 11%, transparent), transparent 70%);"
  >
  </div>
  <div class="wrap py-12 text-center sm:py-14">
    <h2
      class={`mx-auto max-w-[18ch] ${DISPLAY}`}
      style="letter-spacing:-0.01em;"
    >
      Same APIs. <span class="italic text-accent-text"
        >Hold the&nbsp;Chromium.</span
      >
    </h2>
    <p class="mx-auto mt-6 max-w-[42ch] text-text-muted">
      Try it in a weekend. Hate it by Monday, or don't.
    </p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a href="/docs/quickstart" class="btn btn-accent">Get started →</a>
      <a
        href="https://github.com/ipfizz/bunmaska"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost">GitHub</a
      >
    </div>
  </div>
</section>
