{
  "name": "bunmaska",
  "version": "0.1.0-alpha.2",
  "description": "A drop-in replacement for Electron, built on Bun and system WebKit.",
  "keywords": [
    "electron",
    "electron-alternative",
    "bun",
    "webkit",
    "wkwebview",
    "webkitgtk",
    "desktop",
    "gui",
    "ffi",
    "cross-platform",
    "no-chromium"
  ],
  "license": "MIT",
  "author": "Indrajeet O.",
  "homepage": "https://github.com/ipfizz/bunmaska",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ipfizz/bunmaska.git"
  },
  "bugs": {
    "url": "https://github.com/ipfizz/bunmaska/issues"
  },
  "type": "module",
  "bin": {
    "bunmaska": "./src/cli/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./main": {
      "types": "./src/main/index.ts",
      "import": "./src/main/index.ts"
    },
    "./renderer": {
      "types": "./src/renderer/index.ts",
      "import": "./src/renderer/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    },
    "./electron": {
      "types": "./src/electron.ts",
      "import": "./src/electron.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "test": "bun test --timeout 30000",
    "test:watch": "bun test --watch",
    "validate": "bun run format:check && bun run lint && bun run type-check && bun run test",
    "validate:windows": "bun run format:check && bun run lint && bun run type-check && bun test tests/unit/main/platform/windows tests/integration/windows --timeout 60000",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "bun run validate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "typescript": "6.0.3"
  }
}
